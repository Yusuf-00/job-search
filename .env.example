# --- Supabase (Postgres) ---
# Project Settings -> Database -> Connection string (use the "session" pooler, port 5432)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:5432/postgres
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxxx   # Project Settings -> API -> service_role (server-side only, never expose to client)

# --- Meilisearch ---
MEILI_URL=http://localhost:7700   # or your Meilisearch Cloud URL in prod
MEILI_MASTER_KEY=dev_master_key_change_me

# --- ETL ---
CSV_DATA_DIR=./data   # where you unzip the Kaggle archive.zip

# --- Next.js ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
